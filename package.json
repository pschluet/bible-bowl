    "@types/react": "^19",
    "@types/react-dom": "^19",
    "aws-cdk-lib": "^2.244.0",
    "constructs": "^10.6.0",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
